{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "woo-taxonomy-blocks/taxonomy-grid",
  "version": "1.0.0",
  "title": "Taxonomy Grid",
  "category": "woocommerce",
  "icon": "grid-view",
  "description": "Display WooCommerce taxonomy terms as a responsive grid of cards.",
  "keywords": [ "taxonomy", "categories", "tags", "woocommerce", "grid" ],
  "supports": {
    "html": false,
    "align": [ "wide", "full" ],
    "color": { "background": true, "text": true },
    "spacing": { "padding": true, "margin": true }
  },
  "attributes": {
    "taxonomy":          { "type": "string",  "default": "product_cat" },
    "termIds":           { "type": "array",   "default": [], "items": { "type": "integer" } },
    "limit":             { "type": "integer", "default": 6 },
    "orderby":           { "type": "string",  "default": "name" },
    "order":             { "type": "string",  "default": "ASC" },
    "hideEmpty":         { "type": "boolean", "default": true },
    "columns":           { "type": "integer", "default": 3 },
    "aspectRatio":       { "type": "string",  "default": "4/3" },
    "imageSize":         { "type": "string",  "default": "medium" },
    "showCount":         { "type": "boolean", "default": true },
    "showDescription":   { "type": "boolean", "default": false },
    "cardBorderRadius":  { "type": "integer", "default": 8 },
    "cardShadow":        { "type": "boolean", "default": true },
    "hoverEffect":       { "type": "string",  "default": "lift" },
    "placeholderImageId":   { "type": "integer", "default": 0 },
    "placeholderColor":     { "type": "string",  "default": "#f0f0f0" },
    "showAlphabetFilter":   { "type": "boolean", "default": false },
    "showSearch":           { "type": "boolean", "default": false },
    "searchPlaceholder":    { "type": "string",  "default": "" }
  },
  "textdomain": "woo-taxonomy-blocks",
  "editorScript": "file:./index.js",
  "viewScript": "file:./view.js",
  "style": "file:./style-index.css",
  "render": "file:./render.php"
}
